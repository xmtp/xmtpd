# Payer wallet private key (secp256k1)
PAYER_PRIVATE_KEY=0x...

# Redis (default: redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# App Chain (XMTP L3) - get from Alchemy
APP_CHAIN_RPC_URL=https://xmtp-ropsten.g.alchemy.com/v2/YOUR_KEY
APP_CHAIN_WSS_URL=wss://xmtp-ropsten.g.alchemy.com/v2/YOUR_KEY

# Settlement Chain (Base Sepolia) - get from Alchemy
SETTLEMENT_CHAIN_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
SETTLEMENT_CHAIN_WSS_URL=wss://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Environment: testnet or mainnet
CONTRACTS_ENVIRONMENT=testnet

# Log level: debug, info, warn, error
LOG_LEVEL=info
